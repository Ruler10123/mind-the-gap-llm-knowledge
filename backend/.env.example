# ----- Minimal local mode -----
# Empty file works. App boots with stub LLM, local in-memory RAG, no TTS.

# ----- LLM provider -----
# One of: stub | vultr | openai
LLM_PROVIDER=stub

# Used when LLM_PROVIDER=vultr
VULTR_API_KEY=
VULTR_MODEL=llama-3.1-70b-instruct-fp8

# Used when LLM_PROVIDER=openai (any OpenAI-compatible endpoint works)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ----- TTS (optional). Leave blank to disable audio streaming. -----
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ----- Weather tool (optional). Falls back to mock data when blank. -----
OPENWEATHER_API_KEY=

# ----- RAG -----
# RAG_BACKEND=local  uses the in-memory keyword retriever over rag/documents/
# RAG_BACKEND=mongo  uses MongoDB Atlas Vector Search (requires the vars below)
RAG_BACKEND=local
# RAG_MONGO_URI=
# EMBEDDING_MODEL=all-mpnet-base-v2

# ----- Kiosk demo (face auth + flights REST). Disabled by default. -----
# Requires MongoDB + DeepFace. Only enable if you need the legacy demo flows.
ENABLE_KIOSK_DEMO=false
AUTH_MONGO_URI=mongodb://localhost:27017
AUTH_DATABASE_NAME=access_control
AUTH_COLLECTION_NAME=users
AUTH_VECTOR_INDEX_NAME=face_vector_index
FACE_SIMILARITY_THRESHOLD=0.6
FLIGHTS_DATABASE_NAME=flights
FLIGHTS_COLLECTION_NAME=flights_collection
